# FlirtDK v2 – miljoevariabler. Kopieer til .env

PORT=3000
BASE_URL=https://din-app.up.railway.app
JWT_SECRET=skift-dette-til-en-meget-lang-hemmelig-streng

# Gmail App Password: myaccount.google.com -> Sikkerhed -> App-adgangskoder
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=din-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Stripe: dashboard.stripe.com -> Developers -> API keys
STRIPE_SECRET=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_HALFYEAR=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxxxxxxxxxx

# Generer VAPID-nogler:
# node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC=BExamplePublicKey...
VAPID_PRIVATE=ExamplePrivateKey...
